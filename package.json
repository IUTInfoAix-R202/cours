{
  "private": true,
  "name": "cours-r202",
  "description": "R2.02 — Cours magistraux (build Marp + Kroki)",
  "scripts": {
    "dev": "marp --config marp.config.js --server --html .",
    "build": "npm run build:html",
    "build:html": "mkdir -p _site && for f in cm*.md; do npx marp --config marp.config.js --html \"$f\" --output \"_site/${f%.md}.html\"; done",
    "build:all": "bash scripts/build-all.sh",
    "kroki:render": "bash scripts/render-kroki.sh",
    "preview": "marp --config marp.config.js --preview --html cm*.md"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4",
    "@kazumatu981/markdown-it-kroki": "^1"
  }
}
